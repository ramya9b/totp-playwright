# ==============================================
# D365 Environment Configuration
# ==============================================

# D365 Environment URL
D365_URL=https://your-environment.sandbox.operations.dynamics.com

# ==============================================
# OPTION 1: TOTP Authentication (For Local Development)
# ==============================================

# Microsoft 365 Credentials
M365_USERNAME=your-email@domain.com
M365_PASSWORD=your-password

# TOTP Secret for MFA (from Microsoft Authenticator app setup)
# Get this by setting up Microsoft Authenticator and extracting the secret key
TOTP_SECRET=YOUR_TOTP_SECRET_HERE

# ==============================================
# OPTION 2: Service Principal Authentication (For CI/CD)
# ==============================================

# Azure AD App Registration Credentials
# Required for automated Azure DevOps pipelines
# Leave these empty for local development with TOTP

# Azure Tenant ID (from Azure Portal > Azure Active Directory > Overview)
AZURE_TENANT_ID=your-tenant-id-guid

# Azure App Registration Client ID (from Azure Portal > App Registrations)
AZURE_CLIENT_ID=your-client-id-guid

# Azure App Registration Client Secret (from Azure Portal > App Registrations > Certificates & secrets)
AZURE_CLIENT_SECRET=your-client-secret-value

# ==============================================
# CI Environment Detection
# ==============================================

# Set to "true" in CI/CD pipelines
# Automatically enables Service Principal auth if credentials are provided
CI=false

# ==============================================
# SETUP INSTRUCTIONS
# ==============================================

# LOCAL DEVELOPMENT:
# 1. Copy this file to .env
# 2. Fill in D365_URL, M365_USERNAME, M365_PASSWORD, TOTP_SECRET
# 3. Run: npx playwright test

# AZURE DEVOPS CI/CD:
# 1. Create an Azure AD App Registration:
#    - Go to Azure Portal > Azure Active Directory > App registrations > New registration
#    - Name: "D365-Playwright-Automation"
#    - Supported account types: Single tenant
#    - Click Register
#
# 2. Grant API Permissions:
#    - Go to API permissions > Add a permission
#    - Select "APIs my organization uses" > Search for "Dynamics 365"
#    - Add required permissions (e.g., user_impersonation)
#    - Grant admin consent
#
# 3. Create Client Secret:
#    - Go to Certificates & secrets > New client secret
#    - Description: "Azure DevOps Pipeline"
#    - Expiry: 12 months (or as per policy)
#    - Copy the secret value immediately (it won't be shown again)
#
# 4. Add to Azure DevOps Variable Group:
#    - Create or update "D365-Credentials" Variable Group
#    - Add variables:
#      * D365_URL
#      * AZURE_TENANT_ID
#      * AZURE_CLIENT_ID
#      * AZURE_CLIENT_SECRET (mark as secret)
#    - Link variable group to pipeline
#
# 5. Update azure-pipelines.yml to use Service Principal auth
